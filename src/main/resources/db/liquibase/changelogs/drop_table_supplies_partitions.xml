<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- Legacy table: written only by the CSV partition importer removed in the previous commit.
         Replaced by sharing_agreement/sharing_agreement_file plus supply_partition_coefficient
         (untouched). Empty-and-no-readers was established by code inspection; the precondition
         below enforces it at deploy time instead of trusting that inspection blindly. -->
    <changeSet id="drop_table_supplies_partitions" author="Víctor Cañizares">
        <preConditions onFail="HALT">
            <sqlCheck expectedResult="0">SELECT count(*) FROM supplies_partitions</sqlCheck>
        </preConditions>
        <dropTable tableName="supplies_partitions"/>
        <rollback>
            <createTable tableName="supplies_partitions">
                <column name="id" type="uuid">
                    <constraints primaryKey="true" nullable="false"/>
                </column>
                <column name="supply_id" type="UUID">
                    <constraints foreignKeyName="supplies_partitions_supply_id_fk" referencedTableName="supplies"
                                 referencedColumnNames="id" nullable="false"/>
                </column>
                <column name="sharing_agreement_id" type="UUID">
                    <constraints foreignKeyName="supplies_partitions_sharing_agreement_id_fk" referencedTableName="sharing_agreements"
                                 referencedColumnNames="id" nullable="false"/>
                </column>
                <column name="coefficient" type="FLOAT">
                    <constraints nullable="false"/>
                </column>
            </createTable>
        </rollback>
    </changeSet>

</databaseChangeLog>

<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="add_community_id_to_sharing_agreements" author="Víctor Cañizares">
        <addColumn tableName="sharing_agreements">
            <column name="community_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="sharing_agreements_community_id_fk"
                             referencedTableName="communities" referencedColumnNames="id"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>

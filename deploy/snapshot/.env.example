# Configuration for create-snapshot.sh
#
# Copy this file to ".env" in the same directory and fill in the real values.
# The real ".env" is gitignored and MUST NOT be committed.
# Do read every environment-specific value from here -> do not hardcode it in the script.

# --- Production host (reached over Tailscale via SSH) ---
# Tailscale hostname (or user@host) of the production laptop.
PROD_SSH_HOST=conluz-prod
# Path to the docker compose project on the production host (informational; used for messages).
PROD_COMPOSE_DIR=/home/conluz/conluz/deploy

# --- Production PostgreSQL (READ-ONLY: only pg_dump is run against it) ---
PG_CONTAINER=postgres
PG_USER=luz
PG_DB=conluz_db
# Major version of the prod Postgres image. Selects the ephemeral "postgres:<version>"
# image so that pg_restore is compatible with the dump. Confirm with:
#   ssh "$PROD_SSH_HOST" docker exec postgres postgres --version
PG_VERSION=16
# Password for PG_USER on the PROD database (used only by the read-only pg_dump).
# Do supply it here or via a .pgpass file -> do not commit a real password.
PGPASSWORD=

# --- Production InfluxDB 1.8 (READ-ONLY: only influxd backup is run against it) ---
INFLUX_CONTAINER=influxdb
INFLUX_DB=conluz_db

# --- Ephemeral Postgres container (runs on the prod host; all WRITES happen here) ---
# Name MUST be distinct from the prod containers (PG/INFLUX/APP). The script asserts the
# restore/anonymize target is this container and refuses to touch PG_CONTAINER, and aborts
# up front if this name collides with any production container. No port is published; all
# access is via "docker exec".
EPHEMERAL_PG_CONTAINER=conluz-anon-ephemeral
# Password for the throwaway ephemeral Postgres instance (any value; not sensitive).
EPHEMERAL_PG_PASSWORD=ephemeral

# --- Manifest provenance (optional) ---
# Container running the app; only inspected (read-only) to read the deployed image tag,
# which encodes "<git-tag>-<short-hash>" (see deploy/deploy.sh). Defaults to "conluz".
APP_CONTAINER=conluz

# --- Workstation output ---
# Directory on the workstation where the finished anonymized bundle is written.
OUTPUT_DIR=./snapshots

# backup.env
#
# Configuration for backup.sh. Seeded with the current production values; override per host as
# needed. Sourced by backup.sh (set -o allexport), so use plain KEY=value lines.

# Mountpoint of the external backup drive. backup.sh refuses to write unless this is an actual
# mountpoint (see lib/guard.sh). Everything lands under "$BACKUP_MOUNT"/staging/<UTC-timestamp>/.
BACKUP_MOUNT="/media/data"

# PostgreSQL container name and the superuser role used for the whole-cluster pg_dumpall.
# ("luzgres" is POSTGRES_USER in deploy/.env — the superuser role, not a database.)
PG_CONTAINER="postgres"
PG_SUPERUSER="luzgres"

# InfluxDB (1.8) container name. The portable backup captures the whole instance (all databases
# + metastore); no database name and no credentials are required (backup RPC on 127.0.0.1:8088
# is independent of HTTP auth).
INFLUX_CONTAINER="influxdb"

# Optional: uncomment if this host's Postgres requires a password for pg_dumpall. By default the
# container trusts local-socket connections, so no password is needed.
# PGPASSWORD=""

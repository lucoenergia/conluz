# conluz local data-clone configuration. Copy to .env and adjust.
# This file holds LOCAL throwaway values only. Do NOT put production credentials here, and do NOT
# point any URL at a remote host — the restore guardrails will refuse to run.

# --- Guardrail markers -------------------------------------------------------------------------
# Must be exactly 'local'. An empty/unset value fails closed.
CONLUZ_ENV=local

# Whitespace-separated host/identifier denylist. The restore aborts if any resolved target matches.
CONLUZ_PROD_HOST_DENYLIST="lucobot1 conluz-prod"

# The destructive restore must never target your normal/shared containers. The restore aborts if
# LOCAL_POSTGRES_CONTAINER / LOCAL_INFLUX_CONTAINER matches any of these.
CONLUZ_SHARED_CONTAINER_DENYLIST="postgres influxdb"

# Where snapshot-<UTC>.tar.gz bundles are kept (relative to deploy/local/, or absolute).
BUNDLE_DIR=./bundles

# --- Isolated stack identifiers (used by docker-compose.local.yml + reset + verification) -------
# This stack is SEPARATE from your normal postgres/influxdb (different names, ports, named volumes)
# so the restore can never clobber your dev data. Names must NOT be the shared 'postgres'/'influxdb'.
LOCAL_POSTGRES_CONTAINER=conluz-local-postgres
LOCAL_INFLUX_CONTAINER=conluz-local-influxdb
LOCAL_POSTGRES_PORT=5433     # host port for the isolated Postgres (container stays 5432)
LOCAL_INFLUX_PORT=8087       # host port for the isolated InfluxDB (container stays 8086)
POSTGRES_SUPERUSER=luzgres   # = POSTGRES_USER in deploy/.env (database superuser/owner)
POSTGRES_DB=conluz_db        # target database inside the isolated container
APP_DB_USER=luz              # application role the restored objects are owned by

# --- Application connection overrides for ./gradlew bootRun (Spring relaxed binding) -----------
# Host MUST be loopback. bootRun runs on the host, so it reaches the isolated stack via its ports.
# Keep these ports in sync with LOCAL_POSTGRES_PORT / LOCAL_INFLUX_PORT above.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/conluz_db
SPRING_DATASOURCE_USERNAME=luz
SPRING_DATASOURCE_PASSWORD=blank
SPRING_INFLUXDB_URL=http://localhost:8087
SPRING_INFLUXDB_USERNAME=luz
SPRING_INFLUXDB_PASSWORD=blank
SPRING_INFLUXDB_DATABASE=conluz_db

# Required by the app at startup. Generate a real local key (>= 256 bits); this is a placeholder.
CONLUZ_JWT_SECRET_KEY=replace-with-a-local-only-32-byte-minimum-secret

# --- Optional overrides ------------------------------------------------------------------------
# POSTGRES_MAJOR_EXPECTED=16
# ALLOWED_DOCKER_CONTEXTS="default desktop-linux"

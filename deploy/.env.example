# Sanitized reference example for docker-compose.example.yml.
#
# Copy this file to ".env" in the same directory and fill in your own values:
#   cp .env.example .env
# The real ".env" is gitignored and MUST NOT be committed. Use placeholder/local values only
# here — never a real production credential, hostname, or path.

# --- Conluz application ---
# JWT signing key: >= 256 bits, HMAC-SHA compatible. Generate one with
# org.lucoenergia.conluz.infrastructure.shared.security.JwtSecretKeyGenerator.
CONLUZ_JWT_SECRET_KEY=replace-with-a-32-byte-minimum-secret
# Container image for the app. Defaults to ghcr.io/lucoenergia/conluz:latest in the compose file;
# override here to pin a tag or use a locally built image.
CONLUZ_IMAGE=ghcr.io/lucoenergia/conluz:latest

# --- PostgreSQL ---
POSTGRES_USER=changeme                    # superuser/owner created for the Postgres container
POSTGRES_PASSWORD=changeme                # password for POSTGRES_USER
PATH_TO_POSTGRES_DATA=./postgres          # host path bind-mounted as the Postgres data volume
# JDBC URL the app uses to reach Postgres (database name must match conluz-postgres-init.sh).
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/conluz_db

# --- InfluxDB 1.8 ---
INFLUXDB_ADMIN_USER=changeme              # InfluxDB admin user
INFLUXDB_ADMIN_PASSWORD=changeme          # password for INFLUXDB_ADMIN_USER
INFLUXDB_CONLUZ_USER=changeme             # non-admin user the app authenticates as
INFLUXDB_CONLUZ_USER_PASSWORD=changeme    # password for INFLUXDB_CONLUZ_USER
PATH_TO_INFLUXDB_DATA=./influxdb          # host path bind-mounted as the InfluxDB data volume
SPRING_INFLUXDB_URL=http://influxdb:8086  # URL the app uses to reach InfluxDB
SPRING_INFLUXDB_DATABASE=conluz_db        # InfluxDB database name (must match conluz-influxdb-init.sh)
SPRING_INFLUXDB_USERNAME=changeme         # = INFLUXDB_CONLUZ_USER
SPRING_INFLUXDB_PASSWORD=changeme         # = INFLUXDB_CONLUZ_USER_PASSWORD
